
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // सहायक फंक्शन्स
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'rajahribabakumar@gmail.com'; }

    // यूज़र प्रोफाइल रूल्स
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // पोस्ट (फोटो) रूल्स
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // लाइक और फॉलो के लिए
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // वीडियो प्लेलिस्ट रूल्स - सभी देख सकते हैं, केवल एडमिन बदल सकता है
    match /videos/{videoId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // ऐप सेटिंग्स (AdSense) रूल्स - सभी देख सकते हैं, केवल एडमिन बदल सकता है
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // नियम अपडेटेड: 2024-05-22 (Force Redeploy)
  }
}
