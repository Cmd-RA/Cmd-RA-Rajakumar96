
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // सहायक फंक्शन्स
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'rajahribabakumar@gmail.com'; }

    // यूज़र प्रोफाइल रूल्स
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // पोस्ट (फोटो) रूल्स
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // वीडियो प्लेलिस्ट रूल्स
    match /videos/{videoId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // ऐप सेटिंग्स
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
