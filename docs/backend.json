{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account with profile and payment details.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePhotoUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "bankAccount": { "type": "string" },
        "ifscCode": { "type": "string" },
        "gpayNumber": { "type": "string" },
        "followerCount": { "type": "number" },
        "monetizationEnabled": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Represents a photo post.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "likeIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "photoUrl", "title", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "type": "object",
      "description": "Represents a video post or link.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["youtube", "direct"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "videoUrl", "type", "createdAt"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "type": "object",
      "description": "Global settings for AdSense and moderation.",
      "properties": {
        "id": { "type": "string" },
        "adsenseCode": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "User post document"
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Curated video playlist"
    },
    "/app_settings/global": {
      "schema": { "$ref": "#/entities/AppSetting" },
      "description": "Global application settings"
    }
  }
}